
<!DOCTYPE html>
<html lang="hu">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}Cégértékelő{% endblock %}</title>
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
        {% block stylesheets %}
        {% endblock %}
    </head>
    <body>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
            <div class="container">
                <a class="navbar-brand" href="{{ path('review_index') }}">Cégértékelő</a>
                <div class="navbar-nav">
                    <a class="nav-link" href="{{ path('review_index') }}">Vélemények</a>
                    <a class="nav-link" href="{{ path('review_new') }}">Új vélemény</a>
                    <a class="nav-link" href="{{ path('company_index') }}">Cégek</a>
                </div>
            </div>
        </nav>

        <div class="container pb-5">
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="alert alert-{{ label }}" role="alert">{{ message }}</div>
                {% endfor %}
            {% endfor %}

            {% block body %}{% endblock %}
        </div>

        {% block javascripts %}
        {% endblock %}
    </body>
</html>
