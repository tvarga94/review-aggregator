{% extends 'base.html.twig' %}
{% import 'macros.html.twig' as macros %}

{% block title %}{{ review.companyName }} - Cégértékelő{% endblock %}

{% block body %}
    <a href="{{ path('review_index') }}" class="btn btn-link ps-0 mb-3">&laquo; Vissza a véleményekhez</a>

    <div class="card">
        <div class="card-body">
            <h1 class="card-title">{{ review.companyName }}</h1>
            <div class="mb-3 fs-4">{{ macros.stars(review.rating) }}</div>
            <p class="card-text" style="white-space: pre-line">{{ review.reviewText }}</p>
            <p class="text-muted mb-0">
                Beküldve: {{ review.authorEmail }} &middot; {{ review.createdAt|date('Y.m.d. H:i') }}
            </p>
        </div>
    </div>
{% endblock %}
